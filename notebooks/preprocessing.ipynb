    "factory = StemmerFactory()\n",
    "stemmer = factory.create_stemmer()\n",
    "cache   = {}\n",
    "\n",
    def stemming(tokens):
        hasil = []
        for kata in tokens:
            if kata not in cache:
               cache[kata] = stemmer.stem(kata)
        hasil.append(cache[kata])
        return " ".join(hasil)
    "\n",
    "df[\"stemming\"] = df[\"stopword\"].apply(stemming)\n",
    "df[\"stemming\"].head()"
   ]
